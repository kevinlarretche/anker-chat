<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Juçaí Support Chat</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-brand: #602750;
      --primary-hover: #4A1D3D;
      --brand-bg: #FFFFFF;
      --brand-cream: #F9F7F3;
      --bubble-bot: #F7F5F2;
      --bubble-user: #602750;
      --dark-text: #2C1826;
      --medium-text: #8E7C88;
      --border-soft: rgba(96, 39, 80, 0.15);
      --success-green: #2ECC71;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      background-color: var(--brand-bg);
      color: var(--dark-text);
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    .header {
      background: var(--brand-cream);
      border-bottom: 1px solid var(--border-soft);
      padding: 15px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: var(--shadow-sm);
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-container {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      overflow: hidden;
    }

    .logo-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .header-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--primary-brand);
    }

    .header-text p {
      font-size: 11px;
      color: var(--medium-text);
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .status-dot {
      width: 7px;
      height: 7px;
      background: var(--success-green);
      border-radius: 50%;
    }

    .restart-btn {
      background: none;
      border: none;
      color: var(--medium-text);
      cursor: pointer;
      padding: 8px;
      border-radius: 50%;
      transition: all 0.2s;
    }

    .restart-btn:hover {
      color: var(--primary-brand);
    }

    .chat-window {
      flex: 1;
      overflow-y: auto;
      padding: 25px 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="%23e0e0e0" stroke-width="0.5"/></pattern></defs><rect width="400" height="400" fill="url(%23grid)" opacity="0.3"/></svg>');
    }

    .message-wrapper {
      display: flex;
      flex-direction: column;
      animation: fadeIn 0.4s ease;
      max-width: 85%;
    }

    .message-wrapper.user {
      align-items: flex-end;
    }

    .message-wrapper.bot {
      align-items: flex-start;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .message {
      padding: 14px 18px;
      border-radius: 20px;
      font-size: 14.5px;
      line-height: 1.6;
      position: relative;
      box-shadow: var(--shadow-sm);
    }

    .message.user {
      background: var(--bubble-user);
      color: white;
      border-bottom-right-radius: 4px;
    }

    .message.bot {
      background: var(--bubble-bot);
      color: var(--dark-text);
      border: 1px solid var(--border-soft);
      border-bottom-left-radius: 4px;
    }

    .bot-label {
      font-size: 10px;
      font-weight: 800;
      color: var(--primary-brand);
      text-transform: uppercase;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .message-time {
      font-size: 10px;
      color: var(--medium-text);
      margin-top: 5px;
      text-align: right;
    }

    .message-actions {
      display: flex;
      gap: 8px;
      margin-top: 8px;
      opacity: 0;
      transition: opacity 0.2s;
    }

    .message-wrapper:hover .message-actions {
      opacity: 1;
    }

    .action-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: var(--medium-text);
    }

    .footer-container {
      background: var(--brand-cream);
      padding: 15px 20px 25px 20px;
      border-top: 1px solid var(--border-soft);
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
    }

    .quick-replies {
      display: flex;
      gap: 8px;
      margin-bottom: 15px;
      overflow-x: auto;
      padding-bottom: 8px;
    }

    .qr-btn {
      background: transparent;
      border: 1.5px solid var(--primary-brand);
      color: var(--primary-brand);
      padding: 7px 15px;
      border-radius: 25px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s;
    }

    .qr-btn:hover {
      background: var(--primary-brand);
      color: white;
    }

    .input-wrapper {
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
    }

    .input-wrapper input {
      flex: 1;
      padding: 14px 60px 14px 20px;
      border-radius: 30px;
      border: 1px solid var(--border-soft);
      background: var(--bubble-bot);
      outline: none;
      font-size: 14px;
      transition: border 0.2s;
    }

    .input-wrapper input:focus {
      border-color: var(--primary-brand);
    }

    .send-leaf-btn {
      position: absolute;
      right: 6px;
      background: var(--primary-brand);
      color: white;
      border: none;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .send-leaf-btn:hover {
      transform: scale(1.1) rotate(-10deg);
    }

    .send-leaf-btn svg {
      fill: white;
      width: 20px;
      height: 20px;
    }

    .powered-by {
      text-align: center;
      font-size: 9px;
      color: var(--medium-text);
      margin-top: 15px;
      letter-spacing: 1.5px;
      font-weight: 600;
    }

    @keyframes bounce {
      0%, 80%, 100% { transform: scale(0); }
      40% { transform: scale(1); }
    }

    @media (max-width: 600px) {
      .message-wrapper {
        max-width: 90%;
      }
    }
  </style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <div class="logo-container">
      <img src="https://jucai.global/wp-content/uploads/2023/08/jucai-logo.png" alt="Juçaí Logo">
    </div>
    <div class="header-text">
      <h1>Juçaí Support</h1>
      <p><span class="status-dot"></span> Online | Expert Assistant</p>
    </div>
  </div>
  <button class="restart-btn" id="restart-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
      <path d="M3 3v5h5"></path>
    </svg>
  </button>
</div>

<div class="chat-window" id="chat"></div>

<div class="footer-container">
  <div class="quick-replies" id="quick-replies"></div>
  <div class="input-wrapper">
    <input type="text" id="input" placeholder="Type your message..." autocomplete="off">
    <button class="send-leaf-btn" id="send-btn">
      <svg viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8a7 7 0 0 1-7 7c-1.18 0-2.34-.38-3.39-1.02L11 20z"></path></svg>
    </button>
  </div>
  <div class="powered-by">POWERED BY SQU</div>
</div>

<script>
  const params = new URLSearchParams(window.location.search);
  const productId = params.get('product') || 'JUC-001';

  const CONFIG = {
    bot: "Juçaí Assistant",
    webhook: "https://n8n.srv1208833.hstgr.cloud/webhook/jucai-chat",
    welcome: "Hello! I’m your Juçaí expert. How can I help you today? 🌿",
    questions: ["Our Ingredients", "Is it 100% Organic?", "Sustainability Mission", "Find a Store", "Contact Us"]
  };

  let chatId = 'web_' + Math.random().toString(36).substr(2, 9);
  const chat = document.getElementById('chat');
  const input = document.getElementById('input');

  function addMsg(text, type) {
    const wrapper = document.createElement('div');
    wrapper.className = `message-wrapper ${type}`;
    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

    wrapper.innerHTML = `
      ${type === 'bot' ? `<div class="bot-label"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8a7 7 0 0 1-7 7c-1.18 0-2.34-.38-3.39-1.02L11 20z"></path></svg>${CONFIG.bot}</div>` : ''}
      <div class="message ${type}">${text}</div>
      <div class="message-time">${time}</div>
      ${type === 'bot' ? '<div class="message-actions"><button class="action-btn" title="Like"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg></button></div>' : ''}
    `;
    chat.appendChild(wrapper);
    chat.scrollTop = chat.scrollHeight;
  }

  function showTyping() {
    const div = document.createElement('div');
    div.id = 'typing';
    div.className = 'message-wrapper bot';
    div.innerHTML = `
      <div class="bot-label"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8a7 7 0 0 1-7 7c-1.18 0-2.34-.38-3.39-1.02L11 20z"></path></svg>${CONFIG.bot}</div>
      <div class="message bot" style="display:flex; gap:4px; padding:12px 18px;">
        <span style="width:6px; height:6px; background:#602750; border-radius:50%; animation:bounce 1.4s infinite ease-in-out"></span>
        <span style="width:6px; height:6px; background:#602750; border-radius:50%; animation:bounce 1.4s infinite ease-in-out; animation-delay:0.2s"></span>
        <span style="width:6px; height:6px; background:#602750; border-radius:50%; animation:bounce 1.4s infinite ease-in-out; animation-delay:0.4s"></span>
      </div>
    `;
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
  }

  async function handleSend(textOverride) {
    const text = textOverride || input.value.trim();
    if (!text) return;
    input.value = '';
    document.getElementById('quick-replies').style.display = 'none';

    addMsg(text, 'user');
    showTyping();

    try {
      const res = await fetch(CONFIG.webhook, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, productId, chatId })
      });
      const data = await res.json();
      if (document.getElementById('typing')) document.getElementById('typing').remove();
      addMsg(data.reply || "I'm having a little trouble connecting. Please try again!", 'bot');
    } catch(e) {
      if (document.getElementById('typing')) document.getElementById('typing').remove();
      addMsg("I couldn't reach the server. Please check your connection.", 'bot');
    }
  }

  function init() {
    chat.innerHTML = '';
    addMsg(CONFIG.welcome, 'bot');
    const qr = document.getElementById('quick-replies');
    qr.innerHTML = '';
    qr.style.display = 'flex';
    CONFIG.questions.forEach(q => {
      const b = document.createElement('button');
      b.className = 'qr-btn';
      b.textContent = q;
      b.onclick = () => handleSend(q);
      qr.appendChild(b);
    });
  }

  document.getElementById('send-btn').onclick = () => handleSend();
  input.onkeypress = e => { if (e.key === 'Enter') handleSend(); };
  document.getElementById('restart-btn').onclick = () => { chatId = 'web_' + Math.random().toString(36).substr(2, 9); init(); };

  init();
</script>

</body>
</html>
